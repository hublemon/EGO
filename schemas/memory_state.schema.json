{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EGO Memory State",
  "type": "object",
  "required": [
    "episode_id",
    "step_index",
    "recent_actions",
    "completed_actions"
  ],
  "properties": {
    "episode_id": {
      "type": "string",
      "description": "Episode identifier."
    },
    "step_index": {
      "type": "integer",
      "minimum": 0,
      "description": "Planning step index."
    },
    "recent_actions": {
      "type": "array",
      "description": "Recent action history."
    },
    "completed_actions": {
      "type": "array",
      "description": "Actions marked complete."
    },
    "uncertainty": {
      "type": [
        "number",
        "null"
      ],
      "description": "Optional uncertainty score."
    }
  }
}
